# Generated QA screenshots (recreated by check.py each run)
.qa/*.png

# Prunable raw per-source fetch dumps (CLAUDE.md §6); the durable
# artifacts (report.html, digest.json, audit.json) are committed —
# cloud run containers are ephemeral, the repo is the only durable store
runs/**/.work/

# Artifact-publish prep copy (regenerated by .qa/artifact_prep.py each run)
runs/**/report.artifact.html

# User-local notes (not needed by cloud agent)
.liang/

# Superseded draft notes
draft.md
draft copy.md
